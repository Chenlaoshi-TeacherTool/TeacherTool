<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Theme Activities - Teacher Toolkit</title>

    <style>
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            margin: 0;
            padding: 0;
            background-color: #f8f9fa;
            color: #333;
            line-height: 1.6;
        }

        .header {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 40px 20px;
            text-align: center;
        }

        .header h1 {
            margin-bottom: 10px;
        }

        .back-btn {
            position: absolute;
            top: 20px;
            left: 20px;
            background-color: rgba(255, 255, 255, 0.2);
            border: 1px solid white;
            color: white;
            padding: 10px 15px;
            text-decoration: none;
            border-radius: 5px;
        }

        /* 🔍 SEARCH BOX */
        .search-container {
            text-align: center;
            margin: 20px;
        }

        #searchBox {
            width: 80%;
            max-width: 500px;
            padding: 12px;
            border-radius: 8px;
            border: 1px solid #ccc;
            font-size: 16px;
        }

        .tools-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
            gap: 20px;
            padding: 40px 20px;
            max-width: 1200px;
            margin: 0 auto;
        }

        .tool-card {
            background: white;
            border-radius: 12px;
            padding: 25px;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
            text-align: center;
            transition: transform 0.3s;
        }

        .tool-card:hover {
            transform: translateY(-5px);
        }

        .tool-card h3 {
            color: #667eea;
            margin-bottom: 10px;
        }

        .tool-card p {
            margin-bottom: 15px;
            font-size: 14px;
        }

        .btn {
            background-color: #667eea;
            color: white;
            padding: 10px 18px;
            border: none;
            border-radius: 5px;
            cursor: pointer;
            text-decoration: none;
            display: inline-block;
            font-size: 14px;
        }

        .btn:hover {
            background-color: #5a67d8;
        }

        @media (max-width: 768px) {
            .tools-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>

<body>

    <a href="views/teaching-tools/index.ejs" class="back-btn">← Back to Homepage</a>

    <section class="header">
        <h1>Theme Activities</h1>
        <p>Explore ready-to-use classroom activities by topic.</p>
    </section>

    <!-- 🔍 SEARCH BOX -->
    <div class="search-container">
        <input 
            type="text" 
            id="searchBox" 
            placeholder="🔍 Search themes (e.g. animals, family, colors...)"
            onkeyup="filterThemes()"
        >
    </div>

    <section class="tools-grid">

        <div class="tool-card" data-tags="body parts 身体 部位">
            <h3>🧍 身体部位</h3>
            <p>Body parts vocabulary and games</p>
            <a href="theme-body.ejs" class="btn">Open</a>
        </div>

        <div class="tool-card" data-tags="animals 动物">
            <h3>🐶 动物</h3>
            <p>Animals vocabulary & fun activities</p>
            <a href="theme-animals.ejs" class="btn">Open</a>
        </div>

        <div class="tool-card" data-tags="weather seasons 四季 天气">
            <h3>🌦 四季与天气</h3>
            <p>Seasons and weather practice</p>
            <a href="theme-weather.ejs" class="btn">Open</a>
        </div>

        <div class="tool-card" data-tags="countries 国家">
            <h3>🌍 国家</h3>
            <p>Countries and cultural connections</p>
            <a href="theme-countries.ejs" class="btn">Open</a>
        </div>

        <div class="tool-card" data-tags="family 家人">
            <h3>👨‍👩‍👧 家人</h3>
            <p>Family members vocabulary practice</p>
            <a href="theme-family.ejs" class="btn">Open</a>
        </div>

        <div class="tool-card" data-tags="rooms house 房间">
            <h3>🏠 房间</h3>
            <p>House and rooms vocabulary</p>
            <a href="theme-rooms.ejs" class="btn">Open</a>
        </div>

        <div class="tool-card" data-tags="clothing 服饰 clothes">
            <h3>👕 服饰</h3>
            <p>Clothing vocabulary activities</p>
            <a href="theme-clothing.ejs" class="btn">Open</a>
        </div>

        <div class="tool-card" data-tags="jobs occupations 职业">
            <h3>👩‍🏫 职业</h3>
            <p>Jobs and occupations practice</p>
            <a href="theme-jobs.ejs" class="btn">Open</a>
        </div>

        <div class="tool-card" data-tags="self introduction 自我介绍">
            <h3>🙋 自我介绍</h3>
            <p>Introduce yourself in Chinese</p>
            <a href="theme-intro.ejs" class="btn">Open</a>
        </div>

        <div class="tool-card" data-tags="colors 颜色">
            <h3>🎨 颜色</h3>
            <p>Colors vocabulary games</p>
            <a href="theme-colors.ejs" class="btn">Open</a>
        </div>

        <div class="tool-card" data-tags="pinyin 拼音">
            <h3>🔤 拼音</h3>
            <p>Pinyin practice activities</p>
            <a href="theme-pinyin.ejs" class="btn">Open</a>
        </div>

        <div class="tool-card" data-tags="numbers 数字">
            <h3>🔢 数字</h3>
            <p>Numbers practice and games</p>
            <a href="theme-numbers.ejs" class="btn">Open</a>
        </div>

        <div class="tool-card" data-tags="back to school 返校">
            <h3>🏫 返校活动</h3>
            <p>Back-to-school activities</p>
            <a href="theme-backtoschool.ejs" class="btn">Open</a>
        </div>

        <div class="tool-card" data-tags="festivals holidays 节日">
            <h3>🎉 节日</h3>
            <p>Festivals and cultural holidays</p>
            <a href="theme-festivals.ejs" class="btn">Open</a>
        </div>
 
        <div class="tool-card" data-tags="festivals school 学校">
            <h3>🏫 学校</h3>
            <p>School-related activities</p>
            <a href="theme-school.ejs" class="btn">Open</a>
        </div>
    </section>

    <!-- 🔍 JS SEARCH FUNCTION -->
    <script>
        function filterThemes() {
            let input = document.getElementById("searchBox").value.toLowerCase();
            let cards = document.querySelectorAll(".tool-card");

            cards.forEach(card => {
                let tags = card.getAttribute("data-tags").toLowerCase();
                let text = card.innerText.toLowerCase();

                if (tags.includes(input) || text.includes(input)) {
                    card.style.display = "block";
                } else {
                    card.style.display = "none";
                }
            });
        }
    </script>

</body>
</html>
