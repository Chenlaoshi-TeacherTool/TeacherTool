<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Seasons & Weather</title>
  <style>
    body {
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        margin: 0;
        padding: 0;
        background-color: #f8f9fa;
        color: #333;
        line-height: 1.6;
    }

    /* 🌈 HEADER */
    .header {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        padding: 40px 20px;
        text-align: center;
        position: relative;
    }

    .header h1 {
        margin-bottom: 10px;
    }

    .header p {
        opacity: 0.9;
        font-size: 14px;
    }

    .back-btn {
        position: absolute;
        top: 20px;
        left: 20px;
        background-color: rgba(255, 255, 255, 0.2);
        border: 1px solid white;
        color: white;
        padding: 10px 15px;
        text-decoration: none;
        border-radius: 5px;
    }

    .back-btn:hover {
        background-color: rgba(255, 255, 255, 0.3);
    }

    /* 🔍 SEARCH */
    .search-container {
        text-align: center;
        margin: 20px;
    }

    #searchBox {
        width: 80%;
        max-width: 500px;
        padding: 12px;
        border-radius: 8px;
        border: 1px solid #ccc;
        font-size: 16px;
    }

    /* 📦 GRID */
    .tools-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
        gap: 20px;
        padding: 40px 20px;
        max-width: 1200px;
        margin: 0 auto;
    }

    /* 🧩 CARD */
    .tool-card {
        background: white;
        border-radius: 12px;
        padding: 25px;
        box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
        text-align: center;
        transition: transform 0.3s, box-shadow 0.3s;
    }

    .tool-card:hover {
        transform: translateY(-6px);
        box-shadow: 0 8px 15px rgba(0, 0, 0, 0.15);
    }

    .tool-card h3 {
        color: #667eea;
        margin-bottom: 10px;
        font-size: 18px;
    }

    .tool-card p {
        margin-bottom: 15px;
        font-size: 14px;
    }

    /* 🎯 BUTTON */
    .btn {
        background-color: #667eea;
        color: white;
        padding: 10px 18px;
        border: none;
        border-radius: 5px;
        cursor: pointer;
        text-decoration: none;
        display: inline-block;
        font-size: 14px;
    }

    .btn:hover {
        background-color: #5a67d8;
    }

    /* 🌤️ OPTIONAL: Weather color tags（小亮点） */
    .tag {
        display: inline-block;
        font-size: 12px;
        padding: 4px 8px;
        border-radius: 5px;
        margin-bottom: 10px;
        background-color: #eef2ff;
        color: #667eea;
    }

    /* 📱 RESPONSIVE */
    @media (max-width: 768px) {
        .tools-grid {
            grid-template-columns: 1fr;
        }
    }
</style>
</head>
<body>
  <div class="header">
    <a href="index.ejs" class="back-btn">⬅ Back</a>
    <h1>🌦️ 四季与天气</h1>
    <p>Seasons & Weather Activities</p>
</div>

<div class="tools-grid">

    <div class="tool-card">
        <div class="tag">Vocabulary</div>
        <h3>天气词汇</h3>
        <p>Learn weather words like 晴天、下雨、下雪</p>
        <a href="#" class="btn">Open</a>
    </div>

    <div class="tool-card">
        <div class="tag">Practice</div>
        <h3>句型练习</h3>
        <p>Practice “今天天气怎么样？”</p>
        <a href="#" class="btn">Open</a>
    </div>

    <div class="tool-card">
        <div class="tag">Game</div>
        <h3>天气小游戏</h3>
        <p>Interactive classroom activities</p>
        <a href="#" class="btn">Open</a>
    </div>

    <div class="tool-card">
        <div class="tag">Song</div>
        <h3>天气相关歌曲</h3>
        <p>Weather-themed songs for classroom use</p>
        <a href="theme-weather-songs.ejs" class="btn">Open</a>
    </div>

        <div class="tool-card">
        <div class="tag">Hands-on Activity</div>
        <h3>天气相关手工活动</h3>
        <p>Weather-themed hands-on activities for classroom use</p>
        <a href="theme-weather-handsonActivities.ejs" class="btn">Open</a>
    </div>
</div>
</body>
</html>